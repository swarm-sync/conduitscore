# Copy to .env or point REVERSE_FUNNEL_ENV_DIR at the folder that contains .env
# (e.g. C:\Users\...\ .claude\skills\reverse-funnel-scanner)

# --- ConduitScore ---
CONDUITSCORE_API_BASE=https://conduitscore.com
CONDUITSCORE_API_KEY=

# --- Paths ---
# Directory containing cold-email-variants.md (defaults to package data/)
COLD_EMAIL_VARIANTS_PATH=
# Optional: explicit .env directory (parent of this file if unset)
REVERSE_FUNNEL_ENV_DIR=

# --- Harvest ---
USER_AGENT=ReverseFunnelOutreach/0.1 (contact: compliance@yourdomain.com)
HARVEST_MAX_DEPTH=1
HARVEST_SAME_DOMAIN_ONLY=true
USE_CRAWL4AI=true
USE_SCRAPY=true
REQUEST_TIMEOUT_SECONDS=30

# --- Links injected into templates ---
BENCHMARK_LINK=https://conduitscore.com/?utm_source=outreach&utm_medium=email&utm_campaign=benchmark
# Homepage rescan CTA (no private scan id — see ConduitScore docs)
RESCAN_LINK_BASE=https://conduitscore.com/?utm_source=outreach&utm_medium=email&utm_campaign=rescan

# --- From reverse-funnel-scanner (optional integration) ---
SCORE_THRESHOLD=60
RATE_LIMIT_PER_MINUTE=20
YC_API_URL=https://yc-oss.github.io/api/companies/all.json
SENDER_NAME=Ben
UNSUBSCRIBE_URL=https://your-domain.com/unsubscribe
LOG_LEVEL=INFO
