# --- Google Sheet (your blank workbook) ---
GOOGLE_SHEET_ID=1zfvdRw0b870X8d_XfytmB8KRdWn1scEhPEhqh2hpOh0
GOOGLE_SHEET_WORKSHEET=Sheet1
# Download JSON from Google Cloud → IAM → Service account; share the Sheet with the SA email.
# First existing path wins: GOOGLE_SERVICE_ACCOUNT_JSON, GOOGLE_SERVICE_ACCOUNT_FILE, or
# GOOGLE_APPLICATION_CREDENTIALS (often set in the parent repo .env).
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_FILE=

# --- Gmail send (OAuth desktop client JSON from Google Cloud) ---
GMAIL_OAUTH_CREDENTIALS_JSON=
GMAIL_OAUTH_TOKEN_JSON=data/gmail_token.json
# Multi-inbox (same length comma lists, one token file per Gmail):
# GMAIL_OAUTH_CREDENTIALS_JSON=path/c1.json,path/c2.json
# GMAIL_OAUTH_TOKEN_JSON=data/t1.json,data/t2.json
# Or JSON list: GMAIL_SENDER_ROTATION_FILE=data/senders.json
# Optional explicit From: line (must match each token); else Gmail profile email is used.
# SENDER_EMAILS=a@gmail.com,b@gmail.com,c@gmail.com,d@gmail.com,e@gmail.com
GMAIL_DAILY_CAP=35
GMAIL_SEND_PAUSE_SECONDS=2

# --- Sender + compliance ---
SENDER_NAME=Ben
SENDER_EMAIL=
# Public HTTPS URL that handles ?token= for unsubscribe (you host this)
UNSUBSCRIBE_BASE_URL=

# --- ConduitScore (or load from REVERSE_FUNNEL_ENV_DIR skill .env) ---
REVERSE_FUNNEL_ENV_DIR=C:\Users\Administrator\.claude\skills\reverse-funnel-scanner
CONDUITSCORE_API_BASE=https://conduitscore.com
CONDUITSCORE_API_KEY=

# --- Throughput ---
RATE_LIMIT_PER_MINUTE=30
SCAN_CACHE_TTL_HOURS=24
OUTREACH_DB_PATH=data/outreach.db

# --- Optional ---
HTTP_USER_AGENT=ConduitOutreach/1.1
SHEET_SKIP_HEADER_CHECK=0
TEMPLATE_VERSION=
