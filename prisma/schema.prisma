generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  emailVerified    DateTime? @map("email_verified")
  name             String?
  image            String?
  subscriptionTier String    @default("free") @map("subscription_tier")
  stripeCustomerId String?   @map("stripe_customer_id")
  scanCountMonth   Int       @default(0) @map("scan_count_month")
  scanResetAt      DateTime  @default(now()) @map("scan_reset_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  accounts      Account[]
  sessions      Session[]
  scans         Scan[]
  projects      Project[]
  subscription  Subscription?
  payments      Payment[]
  apiKeys       ApiKey[]
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Scan {
  id            String   @id @default(cuid())
  userId        String?  @map("user_id")
  projectId     String?  @map("project_id")
  url           String
  status        String   @default("pending")
  overallScore  Int?     @map("overall_score")
  categoryScores Json?   @map("category_scores")
  issues        Json?
  fixes         Json?
  metadata      Json?
  completedAt   DateTime? @map("completed_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  user    User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  project Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  pages   ScanPage[]
  report  ScanReport?
  @@index([userId])
  @@index([projectId])
  @@map("scans")
}

model ScanPage {
  id       String @id @default(cuid())
  scanId   String @map("scan_id")
  url      String
  scores   Json?
  issues   Json?
  fixes    Json?
  createdAt DateTime @default(now()) @map("created_at")
  scan Scan @relation(fields: [scanId], references: [id], onDelete: Cascade)
  @@map("scan_pages")
}

model Project {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  name      String
  url       String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  scans          Scan[]
  scheduledScans ScheduledScan[]
  @@map("projects")
}

model Subscription {
  id                   String   @id @default(cuid())
  userId               String   @unique @map("user_id")
  stripeSubscriptionId String?  @unique @map("stripe_subscription_id")
  stripePriceId        String?  @map("stripe_price_id")
  status               String   @default("inactive")
  currentPeriodStart   DateTime? @map("current_period_start")
  currentPeriodEnd     DateTime? @map("current_period_end")
  cancelAtPeriodEnd    Boolean  @default(false) @map("cancel_at_period_end")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("subscriptions")
}

model Payment {
  id              String   @id @default(cuid())
  userId          String   @map("user_id")
  stripePaymentId String?  @map("stripe_payment_id")
  amount          Int
  currency        String   @default("usd")
  status          String
  createdAt       DateTime @default(now()) @map("created_at")
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("payments")
}

model ApiKey {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  name      String
  key       String   @unique
  lastUsed  DateTime? @map("last_used")
  createdAt DateTime @default(now()) @map("created_at")
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("api_keys")
}

model ScheduledScan {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  frequency String   @default("weekly")
  lastRun   DateTime? @map("last_run")
  nextRun   DateTime? @map("next_run")
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  @@map("scheduled_scans")
}

model ScanReport {
  id        String   @id @default(cuid())
  scanId    String   @unique @map("scan_id")
  pdfUrl    String?  @map("pdf_url")
  createdAt DateTime @default(now()) @map("created_at")
  scan Scan @relation(fields: [scanId], references: [id], onDelete: Cascade)
  @@map("scan_reports")
}
